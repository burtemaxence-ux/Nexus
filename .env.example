# ATTENTION : Ne jamais committer ce fichier avec de vraies valeurs.
# Copier en .env.local et remplir les valeurs réelles.

# Supabase Configuration
# Récupérez ces valeurs depuis votre tableau de bord Supabase
# Settings > API > Project URL et Project API keys

# URL de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Clé publique (anon key) de votre projet Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clé service role (jamais exposée côté client — serveur uniquement)
# Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — pour l'envoi d'emails (invitations, notifications)
# https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key

# Adresse expéditrice vérifiée dans Resend (ex: noreply@votredomaine.fr)
RESEND_FROM_EMAIL=noreply@votredomaine.fr

# Anthropic — pour l'assistant IA intégré (optionnel)
# https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Secret partagé entre Vercel Cron et les endpoints /api/cron/*
# Générer avec : openssl rand -hex 32
CRON_SECRET=

# iCal token signing secret (OBLIGATOIRE — sans lui le service iCal est indisponible)
# Générer avec : openssl rand -hex 32
CALENDAR_SECRET=

# Vercel KV (rate limiting distribué) — configurer dans Vercel Dashboard > Storage > KV
# Sans ces variables, le rate limiting bascule sur le store in-memory (dev uniquement)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Slack webhook (optionnel) — configurable dans Paramètres > Intégrations
# Créer un Incoming Webhook sur https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Push notifications (Web Push / VAPID)
# Générer avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@nexus-app.fr

# Stripe — paiements et abonnements
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# URL publique de l'application (utilisé pour les redirections Stripe)
NEXT_PUBLIC_APP_URL=https://votre-domaine.com

# Démo — compte pré-créé pour la sandbox
DEMO_USER_EMAIL=demo@votre-domaine.com
DEMO_ESTABLISHMENT_ID=

# Sentry (monitoring erreurs production)
# Récupérer depuis sentry.io → Settings → Projects → ton projet
# DSN : sentry.io → Project Settings → Client Keys (DSN)
# SENTRY_AUTH_TOKEN : sentry.io → Settings → Auth Tokens → Create New Token (scope: project:releases)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
