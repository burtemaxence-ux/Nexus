# ATTENTION : Ne jamais committer ce fichier avec de vraies valeurs.
# Copier en .env.local et remplir les valeurs réelles.

# ─── URL publique du site (OAuth redirect, SEO, emails) ────────────────────────
# Utilisée par : OAuth Google redirect, Stripe checkout/portal, demo login, sitemap
NEXT_PUBLIC_URL=https://quartzbase.fr
# Alias utilisé par certains modules (weekly-brief, SOS) — même valeur que NEXT_PUBLIC_URL
NEXT_PUBLIC_SITE_URL=https://quartzbase.fr

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Récupérez ces valeurs depuis votre tableau de bord Supabase → Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Clé service role (jamais exposée côté client — serveur uniquement)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Resend (emails) ───────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key
# Adresse expéditrice vérifiée dans Resend
RESEND_FROM_EMAIL=noreply@quartzbase.fr

# ─── Anthropic (assistant IA, génération de planning, compliance) ──────────────
# https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-your-api-key

# ─── Secrets ───────────────────────────────────────────────────────────────────
# Secret pour autoriser les crons Vercel (OBLIGATOIRE)
# Si absent → tous les crons retournent 401 silencieusement (aucune erreur visible)
# Générer avec : openssl rand -hex 32
# Doit être configuré dans Vercel Dashboard > Settings > Environment Variables
CRON_SECRET=

# iCal token signing secret (OBLIGATOIRE — sans lui le service iCal est indisponible)
# Générer avec : openssl rand -hex 32
CALENDAR_SECRET=

# ─── Vercel KV (rate limiting distribué) ───────────────────────────────────────
# Configurer dans Vercel Dashboard > Storage > KV
# Sans ces variables, le rate limiting bascule sur le store in-memory (dev uniquement)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Slack (optionnel) ─────────────────────────────────────────────────────────
# Créer un Incoming Webhook sur https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ─── Twilio SMS (optionnel) ────────────────────────────────────────────────────
# https://console.twilio.com — sans ces vars, les SMS sont silencieusement désactivés
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Push notifications (Web Push / VAPID) ─────────────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@quartzbase.fr

# ─── Sentry (monitoring erreurs production) ────────────────────────────────────
# sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Stripe ────────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Price IDs — créer sur dashboard.stripe.com/products (abonnements récurrents)
# Plan Essentiel : 49€/mois ou 490€/an (2 mois offerts)
STRIPE_PRICE_ESSENTIAL_MONTHLY=price_...
STRIPE_PRICE_ESSENTIAL_YEARLY=price_...
# Plan Pro : 89€/mois ou 890€/an (2 mois offerts)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
# Plan Multi-site : 149€/mois ou 1490€/an (2 mois offerts)
STRIPE_PRICE_MULTISITE_MONTHLY=price_...
STRIPE_PRICE_MULTISITE_YEARLY=price_...

# ─── Démo sandbox ──────────────────────────────────────────────────────────────
# Compte démo — créé automatiquement par scripts/seed-demo-quartzbase.sql
DEMO_USER_EMAIL=demo@quartzbase.fr
# ⚠️ OBLIGATOIRE pour la démo — Ne jamais committer de valeur réelle ici
# Choisir un mot de passe fort (min. 12 caractères)
DEMO_USER_PASSWORD=
# UUID de l'établissement démo — affiché dans les logs à la fin du seed SQL
# Procédure : Supabase Dashboard → SQL Editor → exécuter scripts/seed-demo-quartzbase.sql
# Les logs affichent : 👉  DEMO_ESTABLISHMENT_ID = <uuid>
# → Copier cet UUID ici et dans Vercel Dashboard → Settings → Environment Variables
# Si absent : getDemoEstablishmentId() fait un lookup DB automatique (plus lent)
DEMO_ESTABLISHMENT_ID=
